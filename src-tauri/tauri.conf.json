{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Unvaulted",
  "version": "0.1.0",
  "identifier": "com.rifkiadam.unvaulted",
  "mainBinaryName": "Unvaulted",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Unvaulted",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Rifki Adam",
    "copyright": "© 2026 Rifki Adam",
    "shortDescription": "Standalone Obsidian-style markdown editor",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "name": "Text",
        "description": "Text document",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": { "installMode": "currentUser" }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
